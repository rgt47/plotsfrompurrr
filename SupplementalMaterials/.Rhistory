}
f.ggobi.som.net<-function(x.som) {#
  x.net<-NULL#
  for (i in 1:x.som$grid$xdim) {#
    for (j in 1:x.som$grid$ydim) {#
        if (j<x.som$grid$ydim) x.net<-rbind(x.net,c((i-1)*x.som$grid$xdim+j,#
