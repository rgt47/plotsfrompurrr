music.test<-read.csv(file.choose())
music.test$Predict1<-predict(svm1,music.test[,1:90])
i<-1music.test$prediction2<-as.character(NA)while(i<nrow(music.test)+1){  if(music.test$Predict1[i]=="70and90")	{	 music.test$prediction2[i]<-as.character(predict(svm2,music.test[i,1:90]))	}   else	{	  music.test$prediction2[i]<-as.character(predict(svm3,music.test[i,1:90]))	}  	i<-i+1	i}table(music.test$Decade,music.test$prediction2)
