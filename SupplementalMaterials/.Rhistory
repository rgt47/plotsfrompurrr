    if (i<x.som$grid$xdim) x.net<-rbind(x.net,c((i-1)*x.som$grid$xdim+j,#
                       i*x.som$grid$xdim+j))#
    }#
  }#
  colnames(x.net)<-c("from","to")#
  return(x.net)#
}
