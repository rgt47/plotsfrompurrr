names(data.grid) <- tolower(names(data.grid))data.grid$year <- year(data.grid$date)data.grid$yday <- yday(data.grid$date)data.grid$week <- week(data.grid$date)data.grid$dera40_r <- data.grid$dera40 / max(data.grid$dera40)data.grid$obs_r <- data.grid$obs / max(data.grid$obs)
library(lubridate)
names(data.grid) <- tolower(names(data.grid))data.grid$year <- year(data.grid$date)data.grid$yday <- yday(data.grid$date)data.grid$week <- week(data.grid$date)data.grid$dera40_r <- data.grid$dera40 / max(data.grid$dera40)data.grid$obs_r <- data.grid$obs / max(data.grid$obs)
